# Unified Deployment Configuration
# Copy to deployment-config.env and fill in your values

# Basic Configuration
AWS_REGION=us-west-2
AWS_ACCOUNT_ID=<YOUR_ACCOUNT_ID>
STACK_NAME=genomics-vep-s3tables

# Prerequisites Resources
VEP_CACHE_BUCKET=genomics-vep-cache2-<YOUR_ACCOUNT_ID>-us-west-2
CLINVAR_BUCKET=genomics-clinvar2-<YOUR_ACCOUNT_ID>-us-west-2
ECR_REPOSITORY_NAME=ensemblorg/ensembl-vep
VEP_VERSION=release_113.4
REFERENCE_STORE_NAME=genomics-reference-store
REFERENCE_STORE_ID=<YOUR_REFERENCE_STORE_ID>
REFERENCE_ID=<YOUR_REFERENCE_ID>

# S3 Tables Resources
VCF_INPUT_BUCKET=genomics-vcf-input-v3-<YOUR_ACCOUNT_ID>-us-west-2
VEP_OUTPUT_BUCKET=genomics-vep-output-v3-<YOUR_ACCOUNT_ID>-us-west-2
DYNAMODB_TABLE=genomics-vep-s3tables-dynamotable
LAMBDA_ROLE_ARN=arn:aws:iam::<YOUR_ACCOUNT_ID>:role/genomics-vep-s3tables-lambda-execution-role-v3
OMICS_ROLE_ARN=arn:aws:iam::<YOUR_ACCOUNT_ID>:role/genomics-vep-s3tables-healthomics-workflow-role-v3
TABLE_BUCKET_ARN=arn:aws:s3tables:us-west-2:<YOUR_ACCOUNT_ID>:bucket/genomics-variant-tables-<YOUR_ACCOUNT_ID>
WORKFLOW_ID=<YOUR_WORKFLOW_ID>
