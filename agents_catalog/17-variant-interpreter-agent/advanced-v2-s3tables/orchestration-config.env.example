# Pipeline Orchestration Configuration
# Copy to orchestration-config.env and fill in your values

# AWS Batch Resources
BATCH_SERVICE_ROLE_ARN=arn:aws:iam::<YOUR_ACCOUNT_ID>:role/genomics-vep-s3tables-batch-service-role
BATCH_EXECUTION_ROLE_ARN=arn:aws:iam::<YOUR_ACCOUNT_ID>:role/genomics-vep-s3tables-batch-execution-role
BATCH_TASK_ROLE_ARN=arn:aws:iam::<YOUR_ACCOUNT_ID>:role/genomics-vep-s3tables-batch-task-role
BATCH_COMPUTE_ENV_NAME=genomics-vep-s3tables-compute-env
BATCH_JOB_QUEUE_NAME=genomics-vep-s3tables-job-queue
BATCH_JOB_DEFINITION_NAME=genomics-vep-s3tables-s3tables-import-job

# Step Functions
STEP_FUNCTION_ROLE_ARN=
STATE_MACHINE_ARN=

# Lambda Functions
WORKFLOW_TRIGGER_LAMBDA_ARN=arn:aws:lambda:us-west-2:<YOUR_ACCOUNT_ID>:function:genomics-vep-s3tables-workflow-trigger
S3TABLES_IMPORT_LAMBDA_ARN=arn:aws:lambda:us-west-2:<YOUR_ACCOUNT_ID>:function:genomics-vep-s3tables-s3tables-import

# EventBridge
EVENTBRIDGE_RULE_ARN=arn:aws:events:us-west-2:<YOUR_ACCOUNT_ID>:rule/genomics-vep-s3tables-workflow-completion
