FROM public.ecr.aws/lambda/python:3.11

# Install data processing dependencies (pinned to versions with pre-built wheels)
RUN pip install --upgrade pip && \
    pip install --no-cache-dir \
    "numpy<2.1" \
    boto3>=1.34.0 \
    "pyiceberg[s3fs,pyarrow]>=0.7.0,<0.9.0" \
    "pyarrow>=15.0.0,<18.0.0" \
    "pandas>=2.0.0,<2.3.0" \
    s3fs>=2024.2.0 \
    fsspec>=2024.2.0 \
    "smart_open[s3]>=7.0.0"

# Copy application code
COPY load_vcf_schema3.py schema_3.py utils.py ${LAMBDA_TASK_ROOT}/

# Copy the Lambda handler
COPY lambda_s3tables_import.py ${LAMBDA_TASK_ROOT}/

CMD ["lambda_s3tables_import.handler"]
