# AWS Configuration
AWS_REGION=us-west-2
# AWS_PROFILE is important if you have multiple AWS profiles configured
# It tells boto3 which profile to use from ~/.aws/credentials
# If not set, boto3 will use the default profile or IAM role
AWS_PROFILE=himssdemo

# HealthLake Configuration
HEALTHLAKE_DATASTORE_ID=1682549cd71dc2deb7937c768ae3c9fc

# Bedrock Model Configuration
# Using global CRIS (Cross-Region Inference Service) for Claude Opus 4.5
BEDROCK_MODEL_ID=global.anthropic.claude-opus-4-5-20251101-v1:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.3

# API Configuration
PORT=8000
HOST=0.0.0.0

# CORS Configuration (comma-separated origins)
# For development: allow all origins
CORS_ORIGINS=*

# For production: specify your React app's origin
# CORS_ORIGINS=https://your-react-app.com,https://www.your-react-app.com

# Logging
LOG_LEVEL=INFO

# Optional: DynamoDB for interaction logging
# DYNAMODB_INTERACTION_LOGS_TABLE=nlq-interaction-logs
